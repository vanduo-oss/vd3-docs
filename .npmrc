# ═══════════════════════════════════════════════════════
# pnpm Security Configuration — vd2 Project
# ═══════════════════════════════════════════════════════

# ── Supply Chain Protection ──────────────────────────

# Block lifecycle scripts by default (pnpm v10 default, explicit is better)
ignore-scripts=true

# Delay installing newly-published packages by 24 hours.
# Gives the community time to flag malicious versions before they reach us.
minimum-release-age=1440

# Prevent trust-level downgrades on package updates.
# If a package previously had provenance/signatures and a new version doesn't,
# pnpm will refuse to install it.
trust-policy=no-downgrade

# Block transitive dependencies from exotic sources (git repos, tarballs).
# All dependencies must come from the configured registry.
block-exotic-subdeps=true

# ── Determinism & Reproducibility ────────────────────

# Save exact versions (no ^ or ~ ranges) when adding new packages.
save-exact=true

# Strictly enforce peer dependency requirements.
strict-peer-dependencies=true

# ── Registry ─────────────────────────────────────────

# Explicit default registry (defense against registry confusion attacks)
registry=https://registry.npmjs.org/

# Allow the @vanduo-oss/* scope to bypass minimum-release-age so internal
# publishes can be consumed immediately (mirrors docs repo policy).
# Scope-wide pattern: covers core, framework, charts, flowchart, hex-grid,
# music-player, vd2 — all our own first-party publishes.
minimum-release-age-exclude[]=@vanduo-oss/*